{
  "name": "backend",
  "version": "1.0.0",
  "private": true,
  "description": "NestJS backend for Beefree SDK secure authentication",
  "scripts": {
    "dev": "nest start --watch",
    "build": "nest build",
    "start": "node dist/main",
    "type-check": "tsc --project tsconfig.build.json --noEmit",
    "test": "jest --config jest.config.cjs --runInBand",
    "test:coverage": "jest --config jest.config.cjs --runInBand --coverage"
  },
  "dependencies": {
    "@nestjs/common": "^11.1.0",
    "@nestjs/config": "^4.0.0",
    "@nestjs/core": "^11.1.0",
    "@nestjs/platform-express": "^11.1.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.0",
    "reflect-metadata": "^0.2.0",
    "rxjs": "~7.8.0"
  },
  "devDependencies": {
    "@nestjs/cli": "^11.0.0",
    "@nestjs/testing": "^11.1.0",
    "@types/express": "^5.0.0",
    "@types/jest": "^29.5.14",
    "@types/node": "^24.0.0",
    "@types/supertest": "^6.0.3",
    "jest": "^29.7.0",
    "supertest": "^7.1.1",
    "ts-jest": "^29.2.5",
    "typescript": "^5.9.0"
  },
  "packageManager": "yarn@4.13.0"
}
