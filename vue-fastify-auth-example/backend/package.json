{
  "name": "backend",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "Fastify backend for Beefree SDK secure authentication",
  "scripts": {
    "dev": "node ./scripts/run-ts.mjs --watch src/server.ts",
    "build": "tsc",
    "start": "node ./scripts/run-ts.mjs src/server.ts",
    "type-check": "tsc --noEmit",
    "test": "node ./scripts/run-ts.mjs --test src/**/*.test.ts"
  },
  "dependencies": {
    "@fastify/cors": "^11.0.0",
    "@fastify/sensible": "^6.0.0",
    "@sinclair/typebox": "^0.34.0",
    "env-schema": "^6.0.0",
    "fastify": "^5.2.0",
    "fastify-plugin": "^5.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "pino-pretty": "^13.0.0",
    "tsx": "^4.20.0",
    "typescript": "~5.8.0"
  },
  "packageManager": "yarn@4.13.0"
}
