# Beefree SDK credentials (required)
BEEFREE_CLIENT_ID=your_client_id_here
BEEFREE_CLIENT_SECRET=your_client_secret_here

# Server port (example 21: 3000+21)
PORT=3021

# Frontend port (8921 to avoid conflicts with 8021; see example README)
VITE_PORT=8921

# Optional: use shared secure-auth-example server instead of local backend
# VITE_BEEFREE_AUTH_PROXY_URL=http://localhost:3000/auth/token
