              {
                "descriptor": {
                  "computedStyle": {
                    "hideContentOnAmp": false,
                    "hideContentOnDesktop": false,
                    "hideContentOnHtml": false,
                    "hideContentOnMobile": false
                  },
                  "paragraph": {
                    "computedStyle": {
                      "linkColor": "#0068A5",
                      "paragraphSpacing": "16px"
                    },
                    "html": "<p>قابلیت <em><strong>قالب‌های چندزبانه</strong></em> به شما امکان می‌دهد محتوای قالب را ترجمه کنید، اما محتوا را به‌طور خودکار ترجمه <em>نمی‌کند</em>.<br/><br/>لطفاً برای <a href=\"https://docs.beefree.io/beefree-sdk/other-customizations/multi-language-templates\" target=\"_blank\" style=\"text-decoration: underline;\" rel=\"noopener\">اطلاعات بیشتر</a> مستندات را بررسی کنید.</p>",
                    "style": {
                      "color": "#000000",
                      "direction": "rtl",
                      "font-family": "inherit",
                      "font-size": "14px",
                      "font-weight": "400",
                      "letter-spacing": "0px",
                      "line-height": "120%",
                      "text-align": "right"
                    },
                    "translations": {
                      "ar-SA": {
                        "html": "<p>توفر ميزة <em><strong>النماذج متعددة اللغات</strong></em> وسيلة لترجمة محتوى النموذج، ولكنها <em>لا</em> تترجم المحتوى تلقائيًا نيابة عنك.<br/><br/>يرجى الاطلاع على التوثيق <a href=\"https://docs.beefree.io/beefree-sdk/other-customizations/multi-language-templates\" target=\"_blank\" style=\"text-decoration: underline;\" rel=\"noopener\">لمزيد من المعلومات</a>.</p>"
                      },
                      "ckb-IQ": {
                        "html": "<p>تایبەتمەندی <em><strong>قاڵبە زۆر زمانەکان</strong></em> ڕێگایەکی وەرگێڕانی ناوەڕۆکی قاڵبەکەت پێدەدات، بەڵام ناوەڕۆکەکە بە شێوەیەکی خۆکار وەرناگێڕێتەوە.<br/><br/>تکایە <a href=\"https://docs.beefree.io/beefree-sdk/other-customizations/multi-language-templates\" target=\"_blank\" style=\"text-decoration: underline;\" rel=\"noopener\">بەڵگەنامەکان</a> بپشکنە بۆ زانیاری زیاتر.</p>"
                      },
                      "dv-MV": {
                        "html": "<p><em><strong>ބަސްބަސް ޓެމްޕްލޭޓްސް</strong></em> ފީޗާއިން ޓެމްޕްލޭޓް ކޮންޓެންޓް ތަރުޖަމާކުރުމަށް ވަސީލަތެއް ލިބިދޭއިރު، އަމިއްލައަށް ކޮންޓެންޓް ތަރުޖަމާ <em>ނުކުރެވޭނެއެވެ</em>.<br/><br/>އިތުރު މައުލޫމާތު ހޯދުމަށް <a href=\"https://docs.beefree.io/beefree-sdk/other-customizations/multi-language-templates\" target=\"_blank\" style=\"text-decoration: underline;\" rel=\"noopener\">ލިޔުންތައް</a> ބައްލަވާލައްވާށެވެ.</p>"
                      },
                      "ja-JP": {
                        "html": "<p><em><strong>多言語テンプレート</strong></em>機能は、テンプレートのコンテンツを翻訳する手段を提供しますが、コンテンツを自動的には翻訳<em>しません</em>。<br/><br/>詳細については<a href=\"https://docs.beefree.io/beefree-sdk/other-customizations/multi-language-templates\" target=\"_blank\" style=\"text-decoration: underline;\" rel=\"noopener\">ドキュメント</a>をご確認ください。</p>"
                      },
                      "ps-AF": {
                        "html": "<p>د <em><strong>څو ژبنۍ کينډيو</strong></em> ځانګړتیا تاسو ته د کينډۍ منځپانګې د ژباړې لاره چمتو کوي، خو منځپانګه په خپل ځان <em>نه</em> ژباړي.<br/><br/>د نورو معلوماتو لپاره مهرباني وکړئ <a href=\"https://docs.beefree.io/beefree-sdk/other-customizations/multi-language-templates\" target=\"_blank\" style=\"text-decoration: underline;\" rel=\"noopener\">اسناد</a> وګورئ.</p>"
                      },
                      "sd-PK": {
                        "html": "<p><em><strong>گھڻ-ٻولي ٽيمپليٽس</strong></em> جي خاصيت توهان کي ٽيمپليٽ جي مواد کي ترجمو ڪرڻ جو وسيلو ڏئي ٿي، پر پاڻمرادو طور مواد ترجمو <em>نٿو ڪري</em>.<br/><br/>وڌيڪ ڄاڻ لاءِ مھرباني ڪري <a href=\"https://docs.beefree.io/beefree-sdk/other-customizations/multi-language-templates\" target=\"_blank\" style=\"text-decoration: underline;\" rel=\"noopener\">دستاويز</a> ڏسو.</p>"
                      },
                      "tr-TR": {
                        "html": "<p><em><strong>Çoklu dil şablonları</strong></em> özelliği, şablon içeriğini çevirmeniz için bir araç sağlar, ancak içeriği sizin için otomatik olarak çevir<em>mez</em>.<br/><br/>Daha fazla bilgi için lütfen <a href=\"https://docs.beefree.io/beefree-sdk/other-customizations/multi-language-templates\" target=\"_blank\" style=\"text-decoration: underline;\" rel=\"noopener\">belgeleri</a> kontrol edin.</p>"
                      },
                      "ug-CN": {
                        "html": "<p><em><strong>كۆپ تىللىق قېلىپ</strong></em> ئىقتىدارى سىزگە قېلىپ مەزمۇنىنى تەرجىمە قىلىشنىڭ ئۇسۇلىنى تەمىنلەيدۇ، ئەمما مەزمۇننى ئاپتوماتىك ھالدا تەرجىمە قىل<em>مايدۇ</em>.<br/><br/>تېخىمۇ كۆپ ئۇچۇر ئۈچۈن <a href=\"https://docs.beefree.io/beefree-sdk/other-customizations/multi-language-templates\" target=\"_blank\" style=\"text-decoration: underline;\" rel=\"noopener\">پۈتۈكنى</a> تەكشۈرۈڭ.</p>"
                      },
                      "ur-PK": {
                        "html": "<p><em><strong>کثیر اللسانی ٹیمپلیٹس</strong></em> کی خصوصیت آپ کو ٹیمپلیٹ مواد کا ترجمہ کرنے کا ذریعہ فراہم کرتی ہے، لیکن خودکار طور پر مواد کا ترجمہ <em>نہیں</em> کرتی۔<br/><br/>برائے مزید معلومات براہ کرم <a href=\"https://docs.beefree.io/beefree-sdk/other-customizations/multi-language-templates\" target=\"_blank\" style=\"text-decoration: underline;\" rel=\"noopener\">دستاویزات</a> دیکھیں۔</p>"
                      }
                    }
                  },
