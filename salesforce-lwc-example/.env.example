# Beefree SDK Credentials (Backend Only)
# Required for the backend server to authenticate with Beefree API
BEEFREE_CLIENT_ID=your_client_id_here
BEEFREE_CLIENT_SECRET=your_client_secret_here

# Server Configuration
# Port for the Express server (serves auth API)
PORT=3031

# Port for the Vite dev server
VITE_PORT=8031

# Salesforce Configuration
SALESFORCE_ORG_ALIAS=DevOrg
SALESFORCE_USERNAME=your_salesforce_username_here
